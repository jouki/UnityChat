NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgres://postgres:password@localhost:5432/unitychat
LOG_LEVEL=debug

# Comma-separated Chrome extension IDs allowed to hit /streamers/*
# Leave empty in dev to skip the Origin check (logged as warning).
ALLOWED_EXTENSION_IDS=

# Base64-encoded 32-byte key for AES-256-GCM token encryption.
# REQUIRED for OAuth flows (Phase 3+). Leave empty to skip crypto init.
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Public URL the extension uses to reach this backend. Used for building
# OAuth redirect_uri values registered with providers. Example: https://api.jouki.cz
PUBLIC_BASE_URL=http://localhost:3000

# Twitch OAuth app credentials. Register at https://dev.twitch.tv/console/apps
# Redirect URL on Twitch side: {PUBLIC_BASE_URL}/streamers/oauth/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
