NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgres://postgres:password@localhost:5432/unitychat
LOG_LEVEL=debug

# Comma-separated Chrome extension IDs allowed to hit /streamers/*
# Leave empty in dev to skip the Origin check (logged as warning).
ALLOWED_EXTENSION_IDS=

# Base64-encoded 32-byte key for AES-256-GCM token encryption.
# REQUIRED for OAuth flows (Phase 3+). Leave empty to skip crypto init.
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
