{
  "manifest_version": 3,
  "name": "UnityChat",
  "version": "3.3.9",
  "description": "Sjednocený chat z Twitch, YouTube a Kick v jednom panelu",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "scripting",
    "cookies",
    "downloads"
  ],
  "host_permissions": [
    "https://kick.com/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "wss://irc-ws.chat.twitch.tv/*",
    "https://7tv.io/*",
    "https://cdn.7tv.app/*",
    "https://static-cdn.jtvnw.net/*",
    "https://badges.twitch.tv/*",
    "https://files.kick.com/*",
    "https://cdn.betterttv.net/*",
    "https://api.betterttv.net/*",
    "https://api.frankerfacez.com/*",
    "https://cdn.frankerfacez.com/*",
    "https://www.twitch.tv/*",
    "https://twitch.tv/*",
    "https://api.twitch.tv/*",
    "https://gql.twitch.tv/*",
    "https://api.ivr.fi/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "UnityChat - Otevřít sjednocený chat"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content/twitch.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "all_frames": true,
      "js": ["content/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.kick.com/*"],
      "js": ["content/kick.js"],
      "run_at": "document_idle"
    }
  ]
}
